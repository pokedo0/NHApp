{
  "name": "nhappandroid",
  "main": "expo-router/entry",
  "version": "1.1.31",
  "scripts": {
    "sync-version": "node scripts/sync-version.js",
    "android-studio": "npm run sync-version && node ./scripts/sync-android-files.js overrides/android && npx expo prebuild && node ./scripts/prepare-android",
    "android-build": "npm run sync-version && npm run android-studio && npx react-native run-android --mode release",
    "android-sync": "node ./scripts/sync-android-files.js overrides/android",
    "move-apk": "node ./scripts/move-apk.js",
    "android-release:clean": "cd android && gradlew.bat clean || ./gradlew clean",
    "android-release:assemble": "cd android && (gradlew.bat assembleRelease || ./gradlew assembleRelease)",
    "android-release": "npm run android-release:clean && npm run android-release:assemble",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "androidStart": "expo start --android",
    "iosStart": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
