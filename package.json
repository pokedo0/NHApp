{
  "name": "nhappandroid",
  "main": "index.js",
  "version": "1.3.0",
  "scripts": {
    "fixGradle": "node scripts/fixGradle.js",
    "android-apply-defaults": "node scripts/android-apply-defaults.js",
    "android-setup": "npm run fixGradle && npm run android-apply-defaults",
    "sync-version": "node scripts/sync-version.js",
    "android-studio": "npm run sync-version && node ./scripts/sync-android-overrides.js overrides/android && npx expo prebuild && node ./scripts/prepare-android",
    "android-build": "npm run sync-version && npm run android-studio && npx react-native run-android --mode release",
    "android-sync": "node ./scripts/sync-android-overrides.js overrides/android",
    "move-apk": "node ./scripts/move-apk.js",
    "android-release:clean": "cd android && gradlew.bat clean",
    "android-release:assemble": "cd android && gradlew.bat assembleRelease",
    "android-release": "npm run android-release:clean && npm run android-release:assemble",
    "android-clean-deep": "node scripts/android-clean-deep.js",
    "android-release:assemble-only": "cd android && gradlew.bat assembleRelease",
    "android-release:recover": "npm run android-clean-deep && npm run android-release:assemble-only",
    "android:prebuild": "npx expo prebuild --platform android",
    "android:apk:release": "npm run android:prebuild && cd android && gradlew.bat assembleRelease",
    "release:all": "npm run android:apk:release && npm run electron:build:win",
    "start": "expo start",
    "start:lan": "expo start --host lan",
    "reset-project": "node ./scripts/reset-project.js",
    "androidStart": "expo start --android",
    "iosStart": "expo start --ios",
    "web": "expo start --web",
    "build:web": "npx expo export --platform web",
    "build:web:electron": "npx expo export --platform web",
    "build:web:serve": "npx expo export --platform web && npx serve dist",
    "electron": "electron electron/main.js",
    "electron:test": "cross-env ELECTRON_TEST=true NODE_ENV=development electron electron/main.js",
    "electron:dev": "npm run build:web:electron && cross-env NODE_ENV=development electron electron/main.js",
    "electron:build": "npm run build:web:electron && cross-env NODE_ENV=production CSC_IDENTITY_AUTO_DISCOVERY=false WIN_CSC_LINK= electron-builder",
    "electron:build:win": "npm run build:web:electron && cross-env NODE_ENV=production CSC_IDENTITY_AUTO_DISCOVERY=false WIN_CSC_LINK= electron-builder --win",
    "electron:build:linux": "npm run build:web:electron && cross-env NODE_ENV=production CSC_IDENTITY_AUTO_DISCOVERY=false WIN_CSC_LINK= electron-builder --linux",
    "electron:pack": "npm run build:web:electron && cross-env NODE_ENV=production electron-builder --dir",
    "electron:pack:win": "npm run build:web:electron && cross-env NODE_ENV=production CSC_IDENTITY_AUTO_DISCOVERY=false WIN_CSC_LINK= electron-builder --dir --win",
    "lint": "expo lint",
    "audit:fix": "npm audit fix",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@likashefqet/react-native-image-zoom": "^4.3.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-native-community/slider": "5.0.1",
    "@react-native-cookies/cookies": "^6.2.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@shopify/flash-list": "2.0.2",
    "axios": "^1.10.0",
    "date-fns": "^4.1.0",
    "expo": "^54.0.2",
    "expo-application": "~7.0.7",
    "expo-background-task": "~1.0.8",
    "expo-blur": "~15.0.7",
    "expo-clipboard": "~8.0.7",
    "expo-constants": "~18.0.8",
    "expo-crypto": "~15.0.7",
    "expo-dev-client": "~6.0.12",
    "expo-device": "~7.0.1",
    "expo-document-picker": "~14.0.7",
    "expo-file-system": "~19.0.12",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.8",
    "expo-image-manipulator": "~14.0.7",
    "expo-image-picker": "~17.0.10",
    "expo-intent-launcher": "~13.0.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-localization": "~17.0.7",
    "expo-navigation-bar": "~5.0.8",
    "expo-notifications": "~0.32.11",
    "expo-router": "~6.0.1",
    "expo-sharing": "~14.0.7",
    "expo-splash-screen": "~31.0.9",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.7",
    "expo-task-manager": "~14.0.8",
    "expo-video": "~3.0.11",
    "expo-web-browser": "~15.0.7",
    "franc-min": "^6.2.0",
    "lucide-react-native": "^0.526.0",
    "nhentai-api": "^3.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-drawer-layout": "^4.1.12",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-pan-zoom": "^2.1.12",
    "react-native-markdown-display": "^7.0.2",
    "react-native-pager-view": "6.9.1",
    "react-native-progress": "^5.0.1",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-system-setting": "^1.7.6",
    "react-native-tab-view": "^4.1.2",
    "react-native-turnstile": "^1.0.9",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "^19.1.0",
    "@react-native-community/cli-platform-android": "^19.1.0",
    "@svgr/cli": "^8.1.0",
    "@types/expo-localization": "^1.0.1",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "react-native-css-transformer": "^2.0.0",
    "react-native-svg-transformer": "^1.5.1",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "tar": "^7.4.3",
    "minimatch": "^10.2.1",
    "semver": "^7.6.0",
    "glob": "^11.0.0"
  },
  "private": true
}
